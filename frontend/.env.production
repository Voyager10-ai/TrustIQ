# Production environment variables for TrustIQ Frontend
# These values should be added securely inside your Vercel Project Settings -> Environment Variables.

# Backend API URL (HTTPS) - used for REST API calls
# Example: https://trustiq-backend-production.up.railway.app
VITE_API_URL=https://<your-railway-app-name>.up.railway.app

# Backend WebSocket URL (WSS) - used for real-time monitoring
# Example: wss://trustiq-backend-production.up.railway.app
VITE_WS_URL=wss://<your-railway-app-name>.up.railway.app
