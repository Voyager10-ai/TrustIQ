# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=exam_cheater

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Model Configuration
VISION_WEIGHT=0.25
BEHAVIOR_WEIGHT=0.20
AUDIO_WEIGHT=0.20
STYLOMETRY_WEIGHT=0.20
